    "import numpy as np\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Assuming arr is already defined as numpy array\n",
    "arr = np.array(['1,2,3,4'], dtype='<U7')\n",
    "arr = np.array(arr[0].split(','), dtype=int)\n",
    "\n",
    "plt.plot(arr)\n",
    "plt.title('Linear Graph')\n",
    "plt.xlabel('Index')\n",
    "plt.ylabel('Value')\n",
    "plt.show()"
   ]
  }
